# ============================================================================
# Kit Platform V3 — Example environment file
# ----------------------------------------------------------------------------
# Copy this to `.env` for local development. In Railway, set these as
# service-level environment variables (do NOT commit a real .env to git).
# ============================================================================

# ---- Environment -----------------------------------------------------------
ENVIRONMENT=development         # development | staging | production

# ---- Database --------------------------------------------------------------
# Local dev with docker-compose (Postgres service): uses DB below.
# Railway: do NOT set this manually — use Railway's reference var:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://kit:kit@postgres:5432/kit_platform

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash).
CORS_ORIGINS=http://localhost:3010

# ---- Admin Basic Auth ------------------------------------------------------
# Protects /api/admin/* endpoints. Generate a strong password for production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ---- Misc ------------------------------------------------------------------
SEED_ON_STARTUP=true            # set to false in production after first seed

# ---- Frontend (Next.js) ----------------------------------------------------
# Public URL of the backend API (must be reachable from the browser).
NEXT_PUBLIC_API_URL=http://localhost:8010
