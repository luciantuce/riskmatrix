# ============================================================================
# RiskMatrix — unified environment template (root-only)
# ----------------------------------------------------------------------------
# Copy to `.env` for local development.
# In Railway/Cloudflare set real values in platform dashboards.
# ============================================================================

# ============================================================================
# Backend (/backend)
# ============================================================================

# Runtime
ENVIRONMENT=development
PORT=8010

# Database
# Local Docker default; on Railway use injected Postgres DATABASE_URL.
DATABASE_URL=postgresql://kit:kit@postgres:5432/kit_platform

# CORS
# Comma-separated, no trailing slash.
CORS_ORIGINS=http://localhost:3010

# Admin bootstrap credentials (if still enabled in backend config)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Seed data on startup (disable after first production seed)
SEED_ON_STARTUP=true

# Optional IP allowlist gate (empty = disabled)
# ALLOWED_IPS=86.55.123.45,212.45.0.0/24

# Clerk (backend verification + webhooks)
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# FGO (Romanian fiscal invoicing)
FGO_CUI=RO12345678
FGO_PRIVATE_KEY=replace_me
FGO_SERIE=RM
FGO_API_URL=https://api-testuat.fgo.ro/v1

# Resend / email
RESEND_API_KEY=re_replace_me
EMAIL_FROM=RiskMatrix <noreply@riskmatrixai.ro>
APP_URL=http://localhost:3010

# Sentry
SENTRY_DSN_BACKEND=

# ============================================================================
# Frontend app (/frontend)
# ============================================================================

# Public API URL used by browser requests
NEXT_PUBLIC_API_URL=http://localhost:8010

# Next.js runtime port
FRONTEND_PORT=3010

# Clerk (frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Sentry (frontend)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# Landing site (/landing — Cloudflare Pages)
# ============================================================================

# Public links exposed in landing pages
PUBLIC_APP_URL=https://app.riskmatrixai.ro
PUBLIC_API_URL=https://api.riskmatrixai.ro
